# Maintainer: lib32-prebuilts
# Based on official Arch package
# WARNING: This package takes 2-4+ hours to build

pkgname=lib32-webkit2gtk-4.1
pkgver=2.50.5
pkgrel=1
pkgdesc='Web content engine for GTK (32-bit) - JIT disabled for 32-bit compatibility'
arch=('x86_64')
url='https://webkitgtk.org'
license=('LGPL-2.1-or-later')
depends=(
    'lib32-atk'
    'lib32-cairo'
    'lib32-fontconfig'
    'lib32-freetype2'
    'lib32-gdk-pixbuf2'
    'lib32-glib2'
    'lib32-glibc'
    'lib32-gst-plugins-bad-libs'
    'lib32-gst-plugins-base-libs'
    'lib32-gstreamer'
    'lib32-gtk3'
    'lib32-harfbuzz'
    'lib32-harfbuzz-icu'
    'lib32-icu'
    'lib32-lcms2'
    'lib32-libdrm'
    'lib32-libepoxy'
    'lib32-libgcrypt'
    'lib32-libjpeg-turbo'
    'lib32-libpng'
    'lib32-libseccomp'
    'lib32-libsoup3'
    'lib32-libtasn1'
    'lib32-libwebp'
    'lib32-libx11'
    'lib32-libxml2'
    'lib32-libxslt'
    'lib32-sqlite'
    'lib32-wayland'
    'webkit2gtk-4.1'
)
makedepends=(
    'clang'
    'cmake'
    'lld'
    'ninja'
    'glib2-devel'
    'python'
    'ruby'
    'wayland-protocols'
)
provides=(
    'lib32-libjavascriptcoregtk-4.1.so'
    'lib32-libwebkit2gtk-4.1.so'
)
source=("https://webkitgtk.org/releases/webkitgtk-${pkgver}.tar.xz")
sha256sums=('SKIP')

build() {
    cd "webkitgtk-${pkgver}"
    
    export CC='clang -m32'
    export CXX='clang++ -m32'
    export AR='llvm-ar'
    export NM='llvm-nm'
    export RANLIB='llvm-ranlib'
    
    export CFLAGS="-m32 ${CFLAGS}"
    export CXXFLAGS="-m32 ${CXXFLAGS}"
    export LDFLAGS="-m32 -fuse-ld=lld ${LDFLAGS}"
    
    CFLAGS="${CFLAGS/_FORTIFY_SOURCE=3/_FORTIFY_SOURCE=2}"
    CXXFLAGS="${CXXFLAGS/_FORTIFY_SOURCE=3/_FORTIFY_SOURCE=2}"
    
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'
    
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_INSTALL_LIBDIR=lib32 \
        -DCMAKE_INSTALL_LIBEXECDIR=lib32 \
        -DCMAKE_SKIP_RPATH=ON \
        -DPORT=GTK \
        -DENABLE_DOCUMENTATION=OFF \
        -DENABLE_MINIBROWSER=OFF \
        -DENABLE_SPELLCHECK=OFF \
        -DENABLE_SPEECH_SYNTHESIS=OFF \
        -DENABLE_INTROSPECTION=OFF \
        -DENABLE_GAMEPAD=OFF \
        -DENABLE_WEBDRIVER=OFF \
        -DENABLE_JIT=OFF \
        -DENABLE_BUBBLEWRAP_SANDBOX=OFF \
        -DUSE_GTK4=OFF \
        -DUSE_SOUP2=OFF \
        -DUSE_LIBSECRET=OFF \
        -DUSE_ENCHANT=OFF \
        -DUSE_LIBBACKTRACE=OFF \
        -DUSE_WOFF2=OFF \
        -DUSE_OPENJPEG=OFF \
        -DUSE_LIBMANETTE=OFF \
        -DUSE_AVIF=OFF \
        -DUSE_LIBHYPHEN=OFF
    
    cmake --build build
}

package() {
    cd "webkitgtk-${pkgver}"
    DESTDIR="$pkgdir" cmake --install build
    
    rm -rf "${pkgdir}/usr/"{bin,include,share}
    rm -rf "${pkgdir}/usr/lib32/pkgconfig"
    find "${pkgdir}" -name '*.a' -delete
}
