# Maintainer: lib32-gtk4-custom-prebuilt project
# Contributor: Marcell Meszaros < marcell.meszaros AT runbox.eu >
# Contributor: Rodrigo Bezerra <rodrigobezerra21 at gmail dot com>
# Contributor: orumin <dev@orum.in>
#
# This package provides only the libraries from gst-plugins-bad,
# not the actual plugins. This is needed for GTK4's media support.
# Based on gst-plugins-bad 1.24.x structure.

pkgname='lib32-gst-plugins-bad-libs'
_basename='gst-plugins-bad'
pkgver=1.24.0
pkgrel=1
pkgdesc='GStreamer Multimedia Framework Bad Plugin libraries (32-bit)'
arch=('x86_64')
url='https://gstreamer.freedesktop.org/'
license=('LGPL-2.1-or-later')
depends=(
    "lib32-gst-plugins-base-libs>=${pkgver%%.*}"
    'lib32-glib2'
    'lib32-glibc'
    'lib32-orc'
    'gst-plugins-bad-libs'
)
makedepends=(
    'git'
    'meson'
    'glib2-devel'
    'lib32-gcc-libs'
)
optdepends=('lib32-libdrm: drm support'
            'lib32-libva: va support'
            'lib32-wayland: wayland support')
_tarname="${_basename}-${pkgver}"
source=("${_tarname}.tar.xz::${url}src/${_basename}/${_tarname}.tar.xz")
sha256sums=('SKIP')

build() {
  export CC='gcc -m32'
  export CXX='g++ -m32'
  export PKG_CONFIG='/usr/bin/i686-pc-linux-gnu-pkg-config'

  local meson_options=(
    --libdir='/usr/lib32'
    --libexecdir='/usr/lib32'
    -D introspection=disabled
    -D doc=disabled
    -D examples=disabled
    -D tests=disabled
    -D gobject-cast-checks=disabled
    -D glib-asserts=disabled
    -D glib-checks=disabled
    -D opencv=disabled
    -D aja=disabled
    -D va=disabled
    -D msdk=disabled
    -D d3d11=disabled
    -D vulkan=disabled
    -D webrtc=disabled
    -D package-name="Arch Linux ${pkgname} ${pkgver}-${pkgrel}"
    -D package-origin='https://www.archlinux.org/'
  )

  arch-meson "${_tarname}" build "${meson_options[@]}"
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"

  cd "${pkgdir}/usr"
  rm -rf "bin" "include" "share"
  rm -rf "lib32/gstreamer-1.0" 2>/dev/null || true
}
