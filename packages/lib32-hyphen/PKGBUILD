# Maintainer: lib32-prebuilts
# Based on official Arch hyphen package

pkgname=lib32-hyphen
pkgver=2.8.8
pkgrel=1
pkgdesc='Library for high quality hyphenation and justification (32-bit)'
arch=('x86_64')
url='https://hunspell.sourceforge.net'
license=('GPL-2.0-only OR LGPL-2.1-or-later OR MPL-1.1')
depends=('lib32-glibc' 'hyphen')
makedepends=('perl')
source=("https://downloads.sourceforge.net/hunspell/hyphen-$pkgver.tar.gz")
sha256sums=('304636d4eccd81a14b691203d3d8b7892d31046dcb09b202eccd4752b4b36bff')

build() {
    cd "hyphen-$pkgver"
    
    export CC='gcc -m32'
    export CXX='g++ -m32'
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'
    export CFLAGS="-m32 ${CFLAGS}"
    export CXXFLAGS="-m32 ${CXXFLAGS}"
    export LDFLAGS="-m32 ${LDFLAGS}"
    
    ./configure \
        --prefix=/usr \
        --libdir=/usr/lib32
    
    make
}

package() {
    cd "hyphen-$pkgver"
    make DESTDIR="$pkgdir" install
    
    # Remove 64-bit files
    rm -rf "${pkgdir}/usr/"{bin,include,share}
    rm -rf "${pkgdir}/usr/lib"
}
