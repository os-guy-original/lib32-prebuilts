# Maintainer: lib32-prebuilts
# Contributor: Based on AUR lib32-ffmpeg

_pkgname=ffmpeg
pkgname=lib32-$_pkgname
pkgver=8.0.1
pkgrel=1
pkgdesc='Complete solution to record, convert and stream audio and video (32-bit) - minimal build'
arch=('x86_64')
url='https://ffmpeg.org/'
license=('GPL3')
depends=(
    'lib32-glibc'
    'lib32-gmp'
    'lib32-gnutls'
    'lib32-libxml2'
    'lib32-zlib'
    'lib32-bzip2'
    'lib32-xz'
    'lib32-openssl'
    'lib32-libpulse'
    'lib32-alsa-lib'
    'lib32-libx11'
    'lib32-libxcb'
    'lib32-libxext'
    'lib32-libxv'
    'lib32-sdl2'
    'lib32-libva'
    'lib32-libvdpau'
    'lib32-freetype2'
    'lib32-fontconfig'
    'lib32-fribidi'
    'ffmpeg'
)
makedepends=(
    'nasm'
    'yasm'
)
provides=('lib32-libavcodec.so' 'lib32-libavdevice.so' 'lib32-libavfilter.so' 'lib32-libavformat.so'
          'lib32-libavutil.so' 'lib32-libpostproc.so' 'lib32-libswresample.so' 'lib32-libswscale.so')
source=(
    "https://ffmpeg.org/releases/ffmpeg-${pkgver}.tar.xz"
)
sha256sums=('SKIP')

build() {
    cd "${_pkgname}-${pkgver}"

    export CC='gcc -m32'
    export CXX='g++ -m32'
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'

    ./configure \
        --prefix='/usr' \
        --libdir='/usr/lib32' \
        --disable-ffmpeg \
        --disable-ffplay \
        --disable-ffprobe \
        --disable-doc \
        --enable-shared \
        --disable-static \
        --enable-gpl \
        --enable-version3 \
        --disable-cuda-llvm \
        --disable-vulkan \
        --disable-nvenc \
        --disable-nvdec \
        --disable-amf \
        --disable-opencl \
        --disable-libvmaf \
        --disable-vapoursynth \
        --disable-libx264 \
        --disable-libx265 \
        --disable-libvpx \
        --disable-libaom \
        --disable-libdav1d \
        --disable-libopus \
        --disable-libvorbis \
        --disable-libmp3lame \
        --disable-libtheora \
        --disable-libwebp \
        --disable-libass \
        --disable-libfreetype \
        --disable-libfontconfig \
        --disable-libfribidi

    make
}

package() {
    make -C "${_pkgname}-${pkgver}" DESTDIR="${pkgdir}" install

    rm -rf "${pkgdir}/usr/"{bin,include,share}

    install -Dm644 "${_pkgname}-${pkgver}/LICENSE.md" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
