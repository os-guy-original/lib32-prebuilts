# Maintainer: lib32-prebuilts
# Contributor: Based on AUR lib32-ffmpeg

_pkgname=ffmpeg
pkgname=lib32-$_pkgname
pkgver=8.0.1
pkgrel=1
pkgdesc='Complete solution to record, convert and stream audio and video (32-bit)'
arch=('x86_64')
url='https://ffmpeg.org/'
license=('GPL3')
depends=(
    'lib32-glibc'
    'lib32-gmp'
    'lib32-gnutls'
    'lib32-libxml2'
    'lib32-zlib'
    'lib32-bzip2'
    'lib32-xz'
    'lib32-openssl'
    'lib32-libpulse'
    'lib32-alsa-lib'
    'lib32-libx11'
    'lib32-libxcb'
    'lib32-libxext'
    'lib32-libxv'
    'lib32-libvdpau'
    'lib32-libva'
    'lib32-sdl2'
    'lib32-v4l-utils'
    'lib32-libvorbis'
    'lib32-opus'
    'lib32-libtheora'
    'lib32-libvpx'
    'lib32-speex'
    'lib32-libwebp'
    'lib32-freetype2'
    'lib32-fontconfig'
    'lib32-fribidi'
    'lib32-harfbuzz'
    'lib32-libass'
    'lib32-libssh'
    'ffmpeg'
)
makedepends=(
    'nasm'
    'yasm'
)
provides=('lib32-libavcodec.so' 'lib32-libavdevice.so' 'lib32-libavfilter.so' 'lib32-libavformat.so'
          'lib32-libavutil.so' 'lib32-libpostproc.so' 'lib32-libswresample.so' 'lib32-libswscale.so')
source=(
    "https://ffmpeg.org/releases/ffmpeg-${pkgver}.tar.xz"
    '0001-Add-av_stream_get_first_dts-for-Chromium.patch'
    '0001-unbreak-glslang-build.patch'
)
sha256sums=('SKIP'
            'f865d677f8ad39c79dde69186629cb6468c2b289c4156dbb8dec8e68b0131b40'
            '1fc944467ffbd5be38158c3edc587ce15d7509b80c93506016ef183da7eb046b')

prepare() {
    cd "${_pkgname}-${pkgver}"

    patch -Np1 -i "${srcdir}/0001-Add-av_stream_get_first_dts-for-Chromium.patch"
    patch -Np1 -i "${srcdir}/0001-unbreak-glslang-build.patch"
}

build() {
    cd "${_pkgname}-${pkgver}"

    export CC='gcc -m32'
    export CXX='g++ -m32'
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'

    ./configure \
        --prefix='/usr' \
        --libdir='/usr/lib32' \
        --disable-ffmpeg \
        --disable-ffplay \
        --disable-ffprobe \
        --disable-doc \
        --enable-shared \
        --disable-static \
        --enable-gpl \
        --enable-version3 \
        --disable-cuda-llvm \
        --disable-vulkan \
        --disable-nvenc \
        --disable-nvdec \
        --disable-amf \
        --disable-opencl \
        --disable-libvmaf \
        --disable-vapoursynth \
        --disable-libx264 \
        --disable-libx265 \
        --enable-libvpx \
        --enable-libaom \
        --enable-libdav1d \
        --enable-libopus \
        --enable-libvorbis \
        --disable-libmp3lame \
        --enable-libtheora \
        --enable-libwebp \
        --enable-libass

    make
}

package() {
    make -C "${_pkgname}-${pkgver}" DESTDIR="${pkgdir}" install

    rm -rf "${pkgdir}/usr/"{bin,include,share}

    install -Dm644 "${_pkgname}-${pkgver}/LICENSE.md" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
