# Maintainer: lib32-prebuilts
# Based on official Arch package

_basename=gtk4-layer-shell
pkgname=lib32-$_basename
pkgver=1.3.0
pkgrel=1
pkgdesc='Library to create panels and other desktop components for Wayland using Layer Shell protocol and GTK4 (32-bit)'
arch=('x86_64')
url="https://github.com/wmww/gtk4-layer-shell"
license=('MIT')
depends=(
    'lib32-gtk4'
    'lib32-wayland'
    'gtk4-layer-shell'
)
makedepends=(
    'meson'
    'wayland-protocols'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    export CC='gcc -m32'
    export CXX='g++ -m32'
    export PKG_CONFIG_PATH='/usr/lib32/pkgconfig'
    export CFLAGS="-m32 ${CFLAGS}"
    export CXXFLAGS="-m32 ${CXXFLAGS}"
    export LDFLAGS="-m32 ${LDFLAGS}"

    local meson_options=(
        -Dtests=false
        -Ddocs=false
        -Dintrospection=false
        -Dvapi=false
        -Dexamples=false
        -Dsmoke-tests=false
    )

    arch-meson "$_basename-$pkgver" build \
        --libdir=/usr/lib32 \
        --libexecdir=/usr/lib32 \
        "${meson_options[@]}"

    meson compile -C build
}

package() {
    meson install -C build --destdir "$pkgdir"

    # Remove files that conflict with 64-bit package
    rm -rf "${pkgdir}/usr/"{bin,include,share}
}
